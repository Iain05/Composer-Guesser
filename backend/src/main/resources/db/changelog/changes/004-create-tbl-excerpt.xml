<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="004" author="composerguesser">
        <createTable tableName="tbl_excerpt">
            <column name="excerpt_id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="composer_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_excerpt_composer" references="tbl_composer(composer_id)"/>
            </column>
            <column name="uploaded_by_user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_excerpt_user" references="tbl_user(user_id)"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="filename" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="composition_year" type="INT"/>
            <column name="work_number" type="INT"/>
            <column name="description" type="TEXT"/>
            <column name="date_uploaded" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="times_used" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
