<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="009-rename-first-name-to-complete-name" author="composerguesser">
        <renameColumn tableName="tbl_composer"
                      oldColumnName="first_name"
                      newColumnName="complete_name"
                      columnDataType="varchar(255)"/>
    </changeSet>

    <changeSet id="009-drop-number-of-compositions" author="composerguesser">
        <dropColumn tableName="tbl_composer" columnName="number_of_compositions"/>
    </changeSet>

</databaseChangeLog>
