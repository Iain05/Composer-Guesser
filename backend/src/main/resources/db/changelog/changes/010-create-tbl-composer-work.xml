<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="010-create-tbl-composer-work" author="composerguesser">
        <createTable tableName="tbl_composer_work">
            <column name="work_id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="composer_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_composer_work_composer"
                             references="tbl_composer(composer_id)"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="genre" type="VARCHAR(255)"/>
            <column name="year" type="INTEGER"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
